# Copy this to .env and fill in your values
# The Flask app reads these via os.environ

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Leave DB_PASSWORD empty to use SQLite (recommended for local dev)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=indusui_db
DB_USER=root
DB_PASSWORD=

FLASK_DEBUG=true
SECRET_KEY=change-me-in-production
